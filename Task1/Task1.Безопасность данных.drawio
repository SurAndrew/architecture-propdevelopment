        <mxCell id="pS8U7JPrUEjyr9dH34m_-87" value="" style="ellipse;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;strokeColor=#A50040;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontStyle=1;labelBackgroundColor=none;fillColor=#d80073;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="1572" y="128" width="36" height="33" as="geometry" />
        </mxCell>
        <mxCell id="pS8U7JPrUEjyr9dH34m_-97" value="Низкий" style="endArrow=none;html=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;strokeColor=#005700;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;fontStyle=1;labelBackgroundColor=none;fillColor=#008a00;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry x="-0.0435" y="12" width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1640" y="34.83" as="sourcePoint" />
            <mxPoint x="1709" y="34.83" as="targetPoint" />
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="pS8U7JPrUEjyr9dH34m_-98" value="Средний" style="endArrow=none;html=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;strokeColor=#d79b00;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;fontStyle=1;labelBackgroundColor=none;fillColor=#ffe6cc;strokeWidth=3;" edge="1" parent="1">
          <mxGeometry x="-0.0435" y="12" width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1639" y="92" as="sourcePoint" />
            <mxPoint x="1708" y="92" as="targetPoint" />
