        <mxCell id="pS8U7JPrUEjyr9dH34m_-61" value="База данных сервиса аутентификации покупателей" style="text;whiteSpace=wrap;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;fontStyle=1;labelBackgroundColor=none;" vertex="1" parent="1">
          <mxGeometry x="861.335" y="92" width="189.67" height="36" as="geometry" />
        </mxCell>
        <mxCell id="pS8U7JPrUEjyr9dH34m_-63" style="edgeStyle=orthogonalEdgeStyle;shape=connector;curved=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#E07A5F;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;fontStyle=1;labelBackgroundColor=none;endArrow=classic;" edge="1" parent="1" source="pS8U7JPrUEjyr9dH34m_-62" target="Cpsv66eqMkpr9UijDNbB-2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pS8U7JPrUEjyr9dH34m_-62" value="Служба каталогов, которая обслуживает прикладные бизнес-системы и системы обработки данных" style="text;whiteSpace=wrap;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;fontStyle=1;labelBackgroundColor=none;" vertex="1" parent="1">
          <mxGeometry x="861.34" y="155" width="198.33" height="72" as="geometry" />
        </mxCell>
        <mxCell id="pS8U7JPrUEjyr9dH34m_-72" style="edgeStyle=orthogonalEdgeStyle;shape=connector;curved=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;strokeColor=#E07A5F;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;fontStyle=1;labelBackgroundColor=none;endArrow=classic;" edge="1" parent="1" source="pS8U7JPrUEjyr9dH34m_-4" target="pS8U7JPrUEjyr9dH34m_-4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pS8U7JPrUEjyr9dH34m_-85" value="" style="ellipse;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;strokeColor=#005700;fontFamily=Helvetica;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=#ffffff;fontStyle=1;labelBackgroundColor=none;fillColor=#008a00;" vertex="1" parent="1">
